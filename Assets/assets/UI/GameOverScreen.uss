#game-over-screen {
    flex-direction: column;
    width: 100%;
    height: 100%;
    background-color: rgb(12, 10, 18);
    align-items: center;
    justify-content: center;
}

#game-over-title {
    font-size: 72px;
    color: rgb(220, 70, 70);
    -unity-font-style: bold;
    margin-bottom: 36px;
    letter-spacing: 8px;
    -unity-text-align: middle-center;
}

#final-score-label {
    font-size: 52px;
    color: rgb(255, 215, 60);
    -unity-font-style: bold;
    margin-bottom: 14px;
    -unity-text-align: middle-center;
}

#words-found-label {
    font-size: 34px;
    color: rgb(170, 170, 200);
    margin-bottom: 60px;
    -unity-text-align: middle-center;
}

#restart-button, #menu-button {
    width: 260px;
    height: 70px;
    margin: 10px;
    font-size: 28px;
    -unity-font-style: bold;
    border-radius: 12px;
    border-width: 0;
    color: rgb(255, 255, 255);
    cursor: link;
}

#restart-button {
    background-color: rgb(50, 170, 90);
}

#restart-button:hover {
    background-color: rgb(65, 200, 110);
}

#menu-button {
    background-color: rgb(70, 70, 105);
}

#menu-button:hover {
    background-color: rgb(95, 95, 140);
}
